# Hermes Agent configuration for {{ agent_name | title }}
# Managed by Ansible — do not edit manually

identity:
  name: "{{ agent_name | title }}"
  soul: "{{ hermes_install_dir }}/SOUL.md"

providers:
  - id: ollama
    type: openai-compatible
    base_url: "{{ hermes_ollama_base_url }}"
    api_key: "ollama-local"

model:
  primary: "{{ hermes_primary_model }}"
  fallbacks:
{% for model in hermes_fallback_models %}
    - "{{ model }}"
{% endfor %}
  auxiliary:
    conversation: "{{ hermes_auxiliary_conversation_model }}"
    subagent: "{{ hermes_auxiliary_subagent_model }}"

discord:
  enabled: true
  guild_id: "{{ discord_guild_id }}"

memory:
  enabled: {{ hermes_memory_enabled | lower }}
  db_path: "{{ hermes_install_dir }}/memory.db"
  auto_recall: {{ hermes_memory_auto_recall | lower }}
  summarize: {{ hermes_memory_summarize | lower }}

schedule:
  heartbeat: "{{ hermes_heartbeat_interval }}"
  active_hours:
    start: "{{ hermes_active_hours_start }}"
    end: "{{ hermes_active_hours_end }}"
    timezone: "{{ hermes_timezone }}"
