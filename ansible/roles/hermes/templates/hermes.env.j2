# Hermes environment for {{ agent_name | title }}
# Managed by Ansible — mode 0600 — do not edit manually

DISCORD_BOT_TOKEN={{ discord_bot_token }}
DISCORD_ALLOWED_USERS={{ discord_allowed_user_id }}
AGENT_NAME={{ agent_name }}
AGENT_EMAIL={{ agent_email }}

# Use local Ollama as the inference backend (OpenAI-compatible endpoint)
OPENAI_BASE_URL={{ hermes_ollama_base_url }}/v1
OPENAI_API_KEY=ollama
# Model name without provider prefix — base URL already points to Ollama
HERMES_MODEL={{ hermes_primary_model }}
