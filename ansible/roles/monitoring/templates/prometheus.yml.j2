global:
  scrape_interval: {{ prometheus_scrape_interval }}
  evaluation_interval: {{ prometheus_scrape_interval }}

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'proxmox_hosts'
    static_configs:
      - targets:
{% for target in prometheus_proxmox_targets %}
          - '{{ target }}'
{% endfor %}

  - job_name: 'agent_vms'
    static_configs:
      - targets:
{% for target in prometheus_agent_targets %}
          - '{{ target }}'
{% endfor %}

  - job_name: 'monitoring'
    static_configs:
      - targets: ['node_exporter:9100']
