global:
  scrape_interval: {{ prometheus_scrape_interval }}
  evaluation_interval: {{ prometheus_scrape_interval }}

rule_files:
  - /etc/prometheus/rules.yml

scrape_configs:
  # ── Prometheus self ──────────────────────────────────────────────────────────
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  # ── Monitoring VM node_exporter ──────────────────────────────────────────────
  - job_name: 'monitoring'
    static_configs:
      - targets: ['node_exporter:{{ node_exporter_port }}']

  # ── Proxmox hosts — node_exporter :9100 ─────────────────────────────────────
  - job_name: 'proxmox_hosts'
    static_configs:
      - targets:
{% for host in groups['proxmox_hosts'] %}
          - '{{ hostvars[host]['ansible_host'] }}:{{ node_exporter_port }}'
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+):\d+'
        target_label: instance

  # ── Agent VMs — node_exporter :9100 ─────────────────────────────────────────
  - job_name: 'agent_vms'
    static_configs:
      - targets:
{% for host in groups['agent_vms'] %}
          - '{{ hostvars[host]['ansible_host'] }}:{{ node_exporter_port }}'
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+):\d+'
        target_label: instance

  # ── Ceph mgr prometheus module :9283 ─────────────────────────────────────────
  # The active mgr node exposes metrics; all others return empty or error.
  # Scraping all 6 hosts is safe — Prometheus discards empty responses.
  - job_name: 'ceph'
    static_configs:
      - targets:
{% for host in groups['proxmox_hosts'] %}
          - '{{ hostvars[host]['ansible_host'] }}:{{ ceph_exporter_port }}'
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+):\d+'
        target_label: instance

  # ── PVE Exporter — multi-target, one request per PVE host ───────────────────
  - job_name: 'pve'
    static_configs:
      - targets:
{% for host in groups['proxmox_hosts'] %}
          - '{{ hostvars[host]['ansible_host'] }}'
{% endfor %}
    metrics_path: /pve
    params:
      cluster: ['1']
      node: ['1']
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: 'pve_exporter:{{ pve_exporter_port }}'

  # ── IPMI Exporter — remote scrape via iDRAC IPs ──────────────────────────────
  - job_name: 'ipmi'
    params:
      module: [remote]
    static_configs:
      - targets:
{% for host in groups['proxmox_hosts'] %}
          - '{{ hostvars[host]['idrac_ip'] }}'
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: 'ipmi_exporter:{{ ipmi_exporter_port }}'
    scrape_interval: 60s
    scrape_timeout: 30s

  # ── PBS Exporter ──────────────────────────────────────────────────────────────
  - job_name: 'pbs'
    static_configs:
      - targets: ['pbs_exporter:{{ pbs_exporter_port }}']

  # ── Ollama metrics — agent VMs expose /metrics on :11434 ────────────────────
  # Non-fatal if endpoint doesn't exist — Prometheus marks target as down.
  - job_name: 'ollama'
    metrics_path: /metrics
    static_configs:
      - targets:
{% for host in groups['agent_vms'] %}
          - '{{ hostvars[host]['ansible_host'] }}:11434'
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+):\d+'
        target_label: instance

  # ── Service VMs — node_exporter :9100 ────────────────────────────────────────
  # RustDesk (200) and PBS (202) — skip OME (Windows) and monitoring (separate job)
  - job_name: 'service_vms'
    static_configs:
      - targets:
{% for host in groups['service_vms'] %}
{% if 'ome' not in host and 'monitoring' not in host %}
          - '{{ hostvars[host]['ansible_host'] }}:{{ node_exporter_port }}'
{% endif %}
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+):\d+'
        target_label: instance

  # ── UniFi Poller — Dream Machine Pro metrics ─────────────────────────────────
  - job_name: 'unifi'
    static_configs:
      - targets: ['unifi_poller:{{ unifi_poller_port }}']

  # ── NUT Exporter — UPS battery, load, and runtime ────────────────────────────
  - job_name: 'ups'
    static_configs:
      - targets: ['nut_exporter:{{ nut_exporter_port }}']
