modules:
  # Remote IPMI scraping — hits iDRAC IPs over the management network.
  # All 6 Dell servers use the same root credentials.
  remote:
    user: root
    pass: "{{ vault_idrac_password }}"
    driver: "LAN_2_0"
    privilege: "admin"
    timeout: 10000
    collectors:
      - bmc
      - ipmi
      - chassis
