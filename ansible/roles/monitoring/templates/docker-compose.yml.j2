services:
  # ── Prometheus ────────────────────────────────────────────────────────────────
  prometheus:
    image: prom/prometheus:latest
    container_name: prometheus
    restart: unless-stopped
    ports:
      - "9090:9090"
    volumes:
      - {{ monitoring_data_dir }}/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - {{ monitoring_data_dir }}/prometheus/rules.yml:/etc/prometheus/rules.yml:ro
      - prometheus_data:/prometheus
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'
      - '--storage.tsdb.retention.time={{ prometheus_retention }}'
      - '--web.console.libraries=/usr/share/prometheus/console_libraries'
      - '--web.console.templates=/usr/share/prometheus/consoles'
      - '--web.enable-lifecycle'

  # ── Grafana ───────────────────────────────────────────────────────────────────
  grafana:
    image: grafana/grafana:latest
    container_name: grafana
    restart: unless-stopped
    ports:
      - "3000:3000"
    environment:
      GF_SECURITY_ADMIN_USER: "{{ grafana_admin_user }}"
      GF_SECURITY_ADMIN_PASSWORD: "{{ grafana_admin_password }}"
      GF_USERS_ALLOW_SIGN_UP: "false"
      GF_ALERTING_ENABLED: "false"
      GF_UNIFIED_ALERTING_ENABLED: "true"
      GF_DASHBOARDS_DEFAULT_HOME_DASHBOARD_PATH: "/var/lib/grafana/dashboards/olympus-overview.json"
    volumes:
      - grafana_data:/var/lib/grafana
      - {{ monitoring_data_dir }}/grafana/provisioning/datasources:/etc/grafana/provisioning/datasources:ro
      - {{ monitoring_data_dir }}/grafana/provisioning/dashboards:/etc/grafana/provisioning/dashboards:ro
      - {{ monitoring_data_dir }}/grafana/provisioning/alerting:/etc/grafana/provisioning/alerting:ro
      - {{ monitoring_data_dir }}/grafana/dashboards:/var/lib/grafana/dashboards:ro

  # ── Node Exporter (monitoring VM itself) ─────────────────────────────────────
  node_exporter:
    image: prom/node-exporter:latest
    container_name: node_exporter
    restart: unless-stopped
    ports:
      - "{{ node_exporter_port }}:9100"
    volumes:
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /:/rootfs:ro
    command:
      - '--path.procfs=/host/proc'
      - '--path.sysfs=/host/sys'
      - '--collector.filesystem.mount-points-exclude=^/(sys|proc|dev|host|etc)($$|/)'

  # ── PVE Exporter ──────────────────────────────────────────────────────────────
  pve_exporter:
    image: prompve/prometheus-pve-exporter:latest
    container_name: pve_exporter
    restart: unless-stopped
    ports:
      - "{{ pve_exporter_port }}:9221"
    volumes:
      - {{ monitoring_data_dir }}/pve_exporter/pve.yml:/etc/pve.yml:ro
    command:
      - '--config.file=/etc/pve.yml'

  # ── IPMI Exporter ─────────────────────────────────────────────────────────────
  # Scrapes iDRAC IPs remotely over IPMI LAN — no agent needed on hosts.
  ipmi_exporter:
    image: prometheuscommunity/ipmi-exporter:latest
    container_name: ipmi_exporter
    restart: unless-stopped
    ports:
      - "{{ ipmi_exporter_port }}:9290"
    volumes:
      - {{ monitoring_data_dir }}/ipmi/config.yml:/config.yml:ro
    command:
      - '--config.file=/config.yml'

  # ── PBS Exporter ──────────────────────────────────────────────────────────────
  pbs_exporter:
    image: dorfpinguin/pbs-exporter:latest
    container_name: pbs_exporter
    restart: unless-stopped
    ports:
      - "{{ pbs_exporter_port }}:10019"
    command:
      - '-pbs.endpoint=https://{{ pbs_host }}:{{ pbs_port }}'
      - '-pbs.username={{ pbs_api_user }}'
      - '-pbs.api.token.name={{ pbs_api_token_id }}'
      - '-pbs.api.token={{ pbs_api_token_secret }}'
      - '-pbs.insecure=true'

  # ── Loki ──────────────────────────────────────────────────────────────────────
  loki:
    image: grafana/loki:latest
    container_name: loki
    restart: unless-stopped
    ports:
      - "{{ loki_port }}:3100"
    volumes:
      - {{ monitoring_data_dir }}/loki/loki.yml:/etc/loki/loki.yml:ro
      - loki_data:/loki
    command:
      - '--config.file=/etc/loki/loki.yml'

  # ── Promtail ──────────────────────────────────────────────────────────────────
  # Syslog receiver (TCP :1514) + Docker log discovery
  promtail:
    image: grafana/promtail:latest
    container_name: promtail
    restart: unless-stopped
    ports:
      - "{{ promtail_syslog_port }}:{{ promtail_syslog_port }}"
      - "{{ promtail_http_port }}:9080"
    volumes:
      - {{ monitoring_data_dir }}/promtail/promtail.yml:/etc/promtail/promtail.yml:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /var/log:/var/log:ro
    command:
      - '--config.file=/etc/promtail/promtail.yml'

  # ── UniFi Poller ─────────────────────────────────────────────────────────────
  # Scrapes UniFi Dream Machine Pro and exports metrics to Prometheus.
  unifi_poller:
    image: ghcr.io/unpoller/unpoller:latest
    container_name: unifi_poller
    restart: unless-stopped
    ports:
      - "{{ unifi_poller_port }}:9130"
    environment:
      UP_UNIFI_DEFAULT_URL: "https://10.220.1.1"
      UP_UNIFI_DEFAULT_USER: "{{ vault_unifi_poller_user }}"
      UP_UNIFI_DEFAULT_PASS: "{{ vault_unifi_poller_password }}"
      UP_UNIFI_DEFAULT_VERIFY_SSL: "false"
      UP_PROMETHEUS_HTTP_LISTEN: "0.0.0.0:9130"
      UP_INFLUXDB_DISABLE: "true"

  # ── NUT Exporter ──────────────────────────────────────────────────────────────
  # Connects to the NUT server on r640-1:3493 and exposes UPS metrics.
  nut_exporter:
    image: ghcr.io/druggeri/nut_exporter:latest
    container_name: nut_exporter
    restart: unless-stopped
    ports:
      - "{{ nut_exporter_port }}:9199"
    environment:
      NUT_EXPORTER_SERVER: "{{ nut_server_host }}"
      NUT_EXPORTER_PORT: "{{ nut_port }}"
      NUT_EXPORTER_UPS: "{{ nut_ups_names }}"
      NUT_EXPORTER_VARIABLES: "battery.charge,battery.runtime,battery.voltage,battery.voltage.nominal,input.voltage,input.voltage.nominal,output.voltage,ups.load,ups.status"

volumes:
  prometheus_data:
  grafana_data:
  loki_data:
