groups:
  - name: olympus_recording_rules
    interval: 30s
    rules:

      # ── Host / VM CPU ──────────────────────────────────────────────────────
      - record: instance:node_cpu_utilization:ratio
        expr: >
          1 - avg by(instance, job) (
            rate(node_cpu_seconds_total{mode="idle"}[5m])
          )

      # ── Host / VM Memory ───────────────────────────────────────────────────
      - record: instance:node_memory_utilization:ratio
        expr: >
          1 - (
            node_memory_MemAvailable_bytes
            / node_memory_MemTotal_bytes
          )

      # ── Host / VM Root Filesystem ──────────────────────────────────────────
      - record: instance:node_rootfs_utilization:ratio
        expr: >
          1 - (
            node_filesystem_avail_bytes{mountpoint="/", fstype!="rootfs"}
            / node_filesystem_size_bytes{mountpoint="/", fstype!="rootfs"}
          )

      # ── Host / VM Network ──────────────────────────────────────────────────
      - record: instance:node_network_receive_bytes:rate5m
        expr: >
          sum without(device) (
            rate(node_network_receive_bytes_total{
              device!~"lo|veth.*|docker.*|br-.*"
            }[5m])
          )

      - record: instance:node_network_transmit_bytes:rate5m
        expr: >
          sum without(device) (
            rate(node_network_transmit_bytes_total{
              device!~"lo|veth.*|docker.*|br-.*"
            }[5m])
          )

      # ── Ceph Storage ───────────────────────────────────────────────────────
      - record: ceph:osd_up_count
        expr: count(ceph_osd_up == 1)

      - record: ceph:cluster_utilization:ratio
        expr: >
          ceph_cluster_total_used_bytes
          / ceph_cluster_total_bytes

      - record: ceph:total_iops:rate5m
        expr: >
          sum(rate(ceph_pool_rd[5m]))
          + sum(rate(ceph_pool_wr[5m]))

      - record: ceph:total_throughput_bytes:rate5m
        expr: >
          sum(rate(ceph_pool_rd_bytes[5m]))
          + sum(rate(ceph_pool_wr_bytes[5m]))

      # ── IPMI Hardware ──────────────────────────────────────────────────────
      # Uses node_exporter's built-in IPMI collector (node_ipmi_* metrics)
      # on proxmox_hosts — more reliable than the remote ipmi_exporter.
      # instance_name is preserved so dashboards can show short hostnames.
      - record: instance:ipmi_inlet_temp_celsius
        expr: >
          max by(instance, instance_name) (
            node_ipmi_temperature_celsius{job="proxmox_hosts", sensor="Inlet Temp"}
          )

      - record: instance:ipmi_cpu_temp_celsius
        expr: >
          max by(instance, instance_name) (
            node_ipmi_temperature_celsius{job="proxmox_hosts", sensor="Temp"}
          )

      - record: instance:ipmi_power_watts
        expr: >
          node_ipmi_power_watts{job="proxmox_hosts", sensor="Pwr Consumption"}

      - record: instance:ipmi_fan_speed_avg_rpm
        expr: >
          avg by(instance, instance_name) (
            node_ipmi_speed_rpm{job="proxmox_hosts"}
          )

      # ── Service Availability ───────────────────────────────────────────────
      - record: job:up_ratio
        expr: avg by(job) (up)

      # ── Hermes / Ollama service state ──────────────────────────────────────
      - record: instance:hermes_active
        expr: >
          node_systemd_unit_state{
            job="agent_vms",
            name=~"hermes-.+\\.service",
            state="active"
          }

      - record: instance:ollama_active
        expr: >
          node_systemd_unit_state{
            job="agent_vms",
            name="ollama.service",
            state="active"
          }

      # ── UniFi Network ──────────────────────────────────────────────────────
      - record: unifi:wan_rx_bytes:rate5m
        expr: rate(unpoller_device_wan_receive_bytes_total[5m])

      - record: unifi:wan_tx_bytes:rate5m
        expr: rate(unpoller_device_wan_transmit_bytes_total[5m])

      - record: unifi:client_count
        expr: unpoller_site_stations

      - record: unifi:device_memory_utilization:ratio
        expr: unpoller_device_memory_utilization_ratio

      - record: unifi:device_cpu_utilization:ratio
        expr: unpoller_device_cpu_utilization_ratio
