server:
  http_listen_port: {{ promtail_http_port }}
  grpc_listen_port: 0

positions:
  filename: /tmp/positions.yaml

clients:
  - url: http://loki:{{ loki_port }}/loki/api/v1/push

scrape_configs:
  # ── Syslog receiver (TCP, RFC 5424 / RFC 3164) ──────────────────────────────
  # PVE hosts and agent VMs forward syslog here via rsyslog (TCP).
  - job_name: syslog
    syslog:
      listen_address: 0.0.0.0:{{ promtail_syslog_port }}
      listen_protocol: tcp
      idle_timeout: 60s
      label_structured_data: yes
      labels:
        job: syslog
    relabel_configs:
      - source_labels: [__syslog_message_hostname]
        target_label: host
      - source_labels: [__syslog_message_app_name]
        target_label: app
      - source_labels: [__syslog_message_severity]
        target_label: severity

  # ── Syslog receiver (UDP, RFC 3164 / BSD format) ────────────────────────────
  # UniFi UDM sends syslog over UDP in BSD format (no version field).
  - job_name: syslog_udp
    syslog:
      listen_address: 0.0.0.0:{{ promtail_syslog_port }}
      listen_protocol: udp
      syslog_format: rfc3164
      labels:
        job: syslog
    relabel_configs:
      - source_labels: [__syslog_message_hostname]
        target_label: host
      - source_labels: [__syslog_message_app_name]
        target_label: app
      - source_labels: [__syslog_message_severity]
        target_label: severity

  # ── Docker container logs on the monitoring VM ──────────────────────────────
  - job_name: docker
    docker_sd_configs:
      - host: unix:///var/run/docker.sock
        refresh_interval: 5s
    relabel_configs:
      - source_labels: [__meta_docker_container_name]
        regex: '/(.*)'
        target_label: container
      - source_labels: [__meta_docker_container_label_com_docker_compose_service]
        target_label: service
