    {"name": "DS_LOKI", "label": "Loki", "description": "", "type": "datasource", "pluginId": "loki", "pluginName": "Loki"}
  ],
  "__elements": {},
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "bargauge", "name": "Bar gauge", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""},
    {"type": "panel", "id": "logs", "name": "Logs", "version": ""}
  ],
  "annotations": {"list": [{"builtIn": 1, "datasource": {"type": "grafana", "uid": "-- Grafana --"}, "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard"}]},
  "description": "Olympus cluster — deep-dive metrics using recording rules. Variables: $job, $instance.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [{"asDropdown": false, "icon": "external link", "keepTime": true, "title": "Olympus Overview", "type": "link", "url": "/d/olympus-overview"}],
  "panels": [

    { "collapsed": true, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}, "id": 100, "title": "Host Metrics", "type": "row",
      "panels": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "percentunit"}, "overrides": []},
          "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
          "id": 1,
          "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "right"}, "tooltip": {"mode": "multi"}},
          "targets": [
            {
              "datasource": {"type": "prometheus", "uid": "prometheus"},
              "expr": "topk(5, instance:node_cpu_utilization:ratio{job='proxmox_hosts'})",
              "legendFormat": "{{instance}}",
              "refId": "A"
            }
          ],
          "title": "Top 5 CPU — PVE Hosts",
          "type": "timeseries"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "fieldConfig": {
            "defaults": {"color": {"mode": "thresholds"}, "max": 1, "min": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.7}, {"color": "red", "value": 0.85}]}, "unit": "percentunit"},
            "overrides": []
          },
          "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
          "id": 2,
          "options": {"displayMode": "lcd", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showUnfilled": true},
          "targets": [
            {
              "datasource": {"type": "prometheus", "uid": "prometheus"},
              "expr": "instance:node_memory_utilization:ratio{job='proxmox_hosts'}",
              "legendFormat": "{{instance}}",
              "refId": "A"
            }
          ],
          "title": "Memory Usage — PVE Hosts",
          "type": "bargauge"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "Bps"}, "overrides": []},
          "gridPos": {"h": 8, "w": 12, "x": 0, "y": 9},
          "id": 3,
          "options": {"legend": {"calcs": [], "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
          "targets": [
            {
              "datasource": {"type": "prometheus", "uid": "prometheus"},
              "expr": "instance:node_network_receive_bytes:rate5m{job='$job', instance='$instance'}",
              "legendFormat": "{{instance}} RX",
              "refId": "A"
            },
            {
              "datasource": {"type": "prometheus", "uid": "prometheus"},
              "expr": "instance:node_network_transmit_bytes:rate5m{job='$job', instance='$instance'}",
              "legendFormat": "{{instance}} TX",
              "refId": "B"
            }
          ],
          "title": "Network Throughput — $instance",
          "type": "timeseries"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "Bps"}, "overrides": []},
          "gridPos": {"h": 8, "w": 12, "x": 12, "y": 9},
          "id": 4,
          "options": {"legend": {"calcs": [], "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
          "targets": [
            {
              "datasource": {"type": "prometheus", "uid": "prometheus"},
              "expr": "rate(node_disk_read_bytes_total{job='$job', instance='$instance'}[5m])",
              "legendFormat": "{{device}} read",
              "refId": "A"
            },
            {
              "datasource": {"type": "prometheus", "uid": "prometheus"},
              "expr": "rate(node_disk_written_bytes_total{job='$job', instance='$instance'}[5m])",
              "legendFormat": "{{device}} write",
              "refId": "B"
            }
          ],
          "title": "Disk I/O — $instance",
          "type": "timeseries"
        }
      ]
    },

    { "collapsed": true, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 17}, "id": 101, "title": "Ceph Storage", "type": "row",
      "panels": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "iops"}, "overrides": []},
          "gridPos": {"h": 8, "w": 12, "x": 0, "y": 18},
          "id": 10,
          "options": {"legend": {"calcs": [], "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
          "targets": [
            {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "ceph:total_iops:rate5m", "legendFormat": "Total IOPS", "refId": "A"},
            {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(ceph_pool_rd[5m]))", "legendFormat": "Read IOPS", "refId": "B"},
            {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(ceph_pool_wr[5m]))", "legendFormat": "Write IOPS", "refId": "C"}
          ],
          "title": "Ceph IOPS",
          "type": "timeseries"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "Bps"}, "overrides": []},
          "gridPos": {"h": 8, "w": 12, "x": 12, "y": 18},
          "id": 11,
          "options": {"legend": {"calcs": [], "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
          "targets": [
            {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "ceph:total_throughput_bytes:rate5m", "legendFormat": "Total throughput", "refId": "A"}
          ],
          "title": "Ceph Throughput",
          "type": "timeseries"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "max": 1, "min": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.7}, {"color": "red", "value": 0.85}]}, "unit": "percentunit"}, "overrides": []},
          "gridPos": {"h": 8, "w": 12, "x": 0, "y": 26},
          "id": 12,
          "options": {"displayMode": "lcd", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showUnfilled": true},
          "targets": [
            {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "ceph:cluster_utilization:ratio", "legendFormat": "Cluster utilization", "refId": "A"}
          ],
          "title": "Ceph Storage Utilization",
          "type": "bargauge"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "ms"}, "overrides": []},
          "gridPos": {"h": 8, "w": 12, "x": 12, "y": 26},
          "id": 13,
          "options": {"legend": {"calcs": [], "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
          "targets": [
            {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "avg(ceph_osd_apply_latency_ms)", "legendFormat": "Apply latency", "refId": "A"},
            {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "avg(ceph_osd_commit_latency_ms)", "legendFormat": "Commit latency", "refId": "B"}
          ],
          "title": "OSD Latency (avg)",
          "type": "timeseries"
        }
      ]
    },

    { "collapsed": true, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 34}, "id": 102, "title": "IPMI Hardware", "type": "row",
      "panels": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "celsius"}, "overrides": []},
          "gridPos": {"h": 8, "w": 12, "x": 0, "y": 35},
          "id": 20,
          "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "right"}, "tooltip": {"mode": "multi"}},
          "targets": [
            {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "instance:ipmi_inlet_temp_celsius", "legendFormat": "{{instance}} inlet", "refId": "A"},
            {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "instance:ipmi_cpu_temp_celsius", "legendFormat": "{{instance}} CPU", "refId": "B"}
          ],
          "title": "Temperature — All Servers",
          "type": "timeseries"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"fillOpacity": 20, "stacking": {"mode": "normal"}}, "unit": "watt"}, "overrides": []},
          "gridPos": {"h": 8, "w": 12, "x": 12, "y": 35},
          "id": 21,
          "options": {"legend": {"calcs": ["lastNotNull", "mean"], "displayMode": "table", "placement": "right"}, "tooltip": {"mode": "multi"}},
          "targets": [
            {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "instance:ipmi_power_watts", "legendFormat": "{{instance}}", "refId": "A"}
