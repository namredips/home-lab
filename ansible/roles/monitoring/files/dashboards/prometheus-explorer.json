          "gridPos": {"h": 8, "w": 12, "x": 0, "y": 52},
          "id": 32,
          "options": {"legend": {"calcs": [], "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
          "targets": [
            {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "instance:hermes_active", "legendFormat": "{{instance}} hermes", "refId": "A"},
            {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "instance:ollama_active", "legendFormat": "{{instance}} ollama", "refId": "B"}
