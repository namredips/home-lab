  "description": "Olympus cluster overview — 6 PVE hosts, 12 VMs, Ceph storage, PBS backups, OpenClaw agents",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {"asDropdown": false, "icon": "external link", "keepTime": true, "title": "Node Exporter Full", "type": "link", "url": "/d/rYdddlPWk"},
    {"asDropdown": false, "icon": "external link", "keepTime": true, "title": "Ceph Cluster", "type": "link", "url": "/d/tbO9LAiZK"},
    {"asDropdown": false, "icon": "external link", "keepTime": true, "title": "Proxmox VE", "type": "link", "url": "/d/Dp7Cd57Zza"},
    {"asDropdown": false, "icon": "external link", "keepTime": true, "title": "Prometheus Explorer", "type": "link", "url": "/d/prometheus-explorer"}
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "Cluster Health",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"color": "green", "index": 0, "text": "HEALTH_OK"},"1": {"color": "yellow", "index": 1, "text": "HEALTH_WARN"},"2": {"color": "red", "index": 2, "text": "HEALTH_ERR"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 2}]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "ceph_health_status",
          "legendFormat": "Ceph Health",
          "refId": "A"
        }
      ],
      "title": "Ceph Health",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "count(ceph_osd_up == 1)",
          "legendFormat": "OSDs Up",
          "refId": "A"
        }
      ],
      "title": "OSDs Up",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "id": 3,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "ceph_cluster_total_bytes",
          "legendFormat": "Total Storage",
          "refId": "A"
        }
      ],
      "title": "Total Ceph Storage",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.7}, {"color": "red", "value": 0.85}]},
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "id": 4,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "ceph_cluster_total_used_bytes / ceph_cluster_total_bytes",
          "legendFormat": "Storage Used",
          "refId": "A"
        }
      ],
      "title": "Ceph Storage Used %",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "iops"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "id": 5,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(rate(ceph_pool_rd[5m])) + sum(rate(ceph_pool_wr[5m]))",
          "legendFormat": "IOPS",
          "refId": "A"
        }
      ],
      "title": "Ceph IOPS",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1},
      "id": 6,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "count(up{job='proxmox_hosts'} == 1)",
          "legendFormat": "Hosts Online",
          "refId": "A"
        }
      ],
      "title": "PVE Hosts Online",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 101,
      "title": "Host Overview",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "auto", "cellOptions": {"type": "auto"}, "inspect": false},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 75}, {"color": "red", "value": 90}]}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "CPU %"}, "properties": [{"id": "custom.cellOptions", "value": {"mode": "basic", "type": "gauge"}}, {"id": "max", "value": 100}, {"id": "unit", "value": "percent"}]},
          {"matcher": {"id": "byName", "options": "RAM %"}, "properties": [{"id": "custom.cellOptions", "value": {"mode": "basic", "type": "gauge"}}, {"id": "max", "value": 100}, {"id": "unit", "value": "percent"}]},
          {"matcher": {"id": "byName", "options": "Root Disk %"}, "properties": [{"id": "custom.cellOptions", "value": {"mode": "basic", "type": "gauge"}}, {"id": "max", "value": 100}, {"id": "unit", "value": "percent"}]},
          {"matcher": {"id": "byName", "options": "CPU Temp °C"}, "properties": [{"id": "unit", "value": "celsius"}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 65}, {"color": "red", "value": 80}]}}]},
          {"matcher": {"id": "byName", "options": "Power (W)"}, "properties": [{"id": "unit", "value": "watt"}]}
        ]
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 6},
      "id": 10,
      "options": {"footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false}, "showHeader": true, "sortBy": [{"desc": false, "displayName": "Host"}]},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{job='proxmox_hosts',mode='idle'}[5m])) * 100)",
          "format": "table",
          "instant": true,
          "legendFormat": "{{instance}}",
          "refId": "CPU"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "(1 - (node_memory_MemAvailable_bytes{job='proxmox_hosts'} / node_memory_MemTotal_bytes{job='proxmox_hosts'})) * 100",
          "format": "table",
          "instant": true,
          "legendFormat": "{{instance}}",
          "refId": "RAM"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "100 - (node_filesystem_avail_bytes{job='proxmox_hosts',mountpoint='/',fstype!='rootfs'} / node_filesystem_size_bytes{job='proxmox_hosts',mountpoint='/',fstype!='rootfs'} * 100)",
          "format": "table",
          "instant": true,
          "legendFormat": "{{instance}}",
          "refId": "Disk"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "max by(instance) (node_ipmi_temperature_celsius{job='proxmox_hosts',sensor=~'Inlet Temp|Temp'})",
          "format": "table",
          "instant": true,
          "legendFormat": "{{instance}}",
          "refId": "Temp"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "node_ipmi_power_watts{job='proxmox_hosts',sensor='Pwr Consumption'}",
          "format": "table",
          "instant": true,
          "legendFormat": "{{instance}}",
          "refId": "Power"
        }
      ],
      "title": "Host Overview — 6 PVE Nodes",
      "transformations": [
        {
          "id": "joinByField",
          "options": {"byField": "instance", "mode": "outer"}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "instance": "Host",
              "Value #CPU": "CPU %",
              "Value #RAM": "RAM %",
              "Value #Disk": "Root Disk %",
              "Value #Temp": "CPU Temp °C",
              "Value #Power": "Power (W)"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "id": 102,
      "title": "VM Overview",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "auto", "cellOptions": {"type": "auto"}, "inspect": false},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 75}, {"color": "red", "value": 90}]}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "CPU %"}, "properties": [{"id": "custom.cellOptions", "value": {"mode": "basic", "type": "gauge"}}, {"id": "max", "value": 100}, {"id": "unit", "value": "percent"}]},
          {"matcher": {"id": "byName", "options": "RAM %"}, "properties": [{"id": "custom.cellOptions", "value": {"mode": "basic", "type": "gauge"}}, {"id": "max", "value": 100}, {"id": "unit", "value": "percent"}]},
          {"matcher": {"id": "byName", "options": "Uptime"}, "properties": [{"id": "unit", "value": "s"}, {"id": "custom.cellOptions", "value": {"type": "auto"}}]}
        ]
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 15},
      "id": 11,
      "options": {"footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false}, "showHeader": true, "sortBy": [{"desc": false, "displayName": "VM"}]},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{job=~'agent_vms|service_vms',mode='idle'}[5m])) * 100)",
          "format": "table",
          "instant": true,
          "legendFormat": "{{instance}}",
          "refId": "CPU"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "(1 - (node_memory_MemAvailable_bytes{job=~'agent_vms|service_vms'} / node_memory_MemTotal_bytes{job=~'agent_vms|service_vms'})) * 100",
          "format": "table",
          "instant": true,
          "legendFormat": "{{instance}}",
          "refId": "RAM"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "node_time_seconds{job=~'agent_vms|service_vms'} - node_boot_time_seconds{job=~'agent_vms|service_vms'}",
          "format": "table",
          "instant": true,
          "legendFormat": "{{instance}}",
          "refId": "Uptime"
        }
      ],
      "title": "VM Overview — Agent + Service VMs",
      "transformations": [
        {
          "id": "joinByField",
          "options": {"byField": "instance", "mode": "outer"}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "instance": "VM",
              "Value #CPU": "CPU %",
              "Value #RAM": "RAM %",
              "Value #Uptime": "Uptime"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 25},
      "id": 103,
      "title": "Agent Status",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"1": {"color": "green", "index": 0, "text": "active"},"0": {"color": "red", "index": 1, "text": "inactive"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 26},
      "id": 20,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": true}, "textMode": "auto"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "node_systemd_unit_state{job='agent_vms',name=~'hermes-.+\\.service',state='active'}",
          "legendFormat": "{{instance}} hermes",
          "refId": "A"
        }
      ],
      "title": "OpenClaw Service State",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"1": {"color": "green", "index": 0, "text": "active"},"0": {"color": "red", "index": 1, "text": "inactive"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 26},
      "id": 21,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": true}, "textMode": "auto"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "node_systemd_unit_state{job='agent_vms',name='ollama.service',state='active'}",
          "legendFormat": "{{instance}} ollama",
          "refId": "A"
        }
      ],
      "title": "Ollama Service State",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 32},
      "id": 104,
      "title": "PBS Backup Status",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "auto", "cellOptions": {"type": "auto"}, "inspect": false},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 86400}, {"color": "red", "value": 172800}]}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Age (hours)"}, "properties": [{"id": "unit", "value": "h"}, {"id": "custom.cellOptions", "value": {"mode": "basic", "type": "gauge"}}, {"id": "max", "value": 48}]},
          {"matcher": {"id": "byName", "options": "Datastore Used %"}, "properties": [{"id": "unit", "value": "percent"}, {"id": "custom.cellOptions", "value": {"mode": "basic", "type": "gauge"}}, {"id": "max", "value": 100}]}
        ]
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 33},
      "id": 30,
      "options": {"footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false}, "showHeader": true},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "pbs_snapshot_count",
          "format": "table",
          "instant": true,
          "legendFormat": "{{datastore}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "pbs_used / pbs_size * 100",
          "format": "table",
          "instant": true,
          "legendFormat": "{{datastore}}",
          "refId": "B"
        }
      ],
      "title": "PBS Snapshot Count & Datastore Usage",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "datastore": "Datastore",
              "Value #A": "Snapshots",
              "Value #B": "Datastore Used %"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 41},
      "id": 106,
      "title": "UniFi Network",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
