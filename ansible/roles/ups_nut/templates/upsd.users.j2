# /etc/nut/upsd.users — NUT user accounts (NUT server only)
# Managed by Ansible — do not edit manually

# upsmon user — used by all hosts to monitor the UPS
# Must grant "upsmon master" so this user can set the FSD (forced shutdown) flag
[{{ nut_monitor_user }}]
    password  = {{ nut_monitor_password }}
    upsmon master

# Admin user — for manual UPS management commands
[{{ nut_admin_user }}]
    password  = {{ nut_admin_password }}
    actions   = SET
    instcmds  = ALL
