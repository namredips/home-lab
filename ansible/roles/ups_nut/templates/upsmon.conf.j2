# /etc/nut/upsmon.conf — UPS monitor config
# Managed by Ansible — do not edit manually

{% if nut_mode == 'netserver' %}
# This host owns the USB connection — master role
# master = this upsmon can issue FSD and runs the full shutdown script
MONITOR {{ nut_ups_name }}@localhost:{{ nut_port }} 1 {{ nut_monitor_user }} {{ nut_monitor_password }} master
SHUTDOWNCMD "/usr/local/bin/ups-shutdown.sh"
{% else %}
# This host monitors the UPS remotely — slave role
# slave = this upsmon shuts down when master signals FSD
MONITOR {{ nut_ups_name }}@{{ nut_server_host }}:{{ nut_port }} 1 {{ nut_monitor_user }} {{ nut_monitor_password }} slave
SHUTDOWNCMD "/sbin/shutdown -h now"
{% endif %}

# Thresholds — trigger SHUTDOWNCMD when either condition is met
MINSUPPLIES 1
POLLFREQ 5
POLLFREQALERT 5
HOSTSYNC 15
DEADTIME 15

# Notify on state changes
NOTIFYMSG ONLINE    "UPS %s: on line power"
NOTIFYMSG ONBATT    "UPS %s: on battery"
NOTIFYMSG LOWBATT   "UPS %s: battery is low"
NOTIFYMSG FSD       "UPS %s: forced shutdown in progress"
NOTIFYMSG COMMOK    "UPS %s: communications restored"
NOTIFYMSG COMMBAD   "UPS %s: communications lost"
NOTIFYMSG SHUTDOWN  "UPS %s: shutting down"
NOTIFYMSG REPLBATT  "UPS %s: battery needs replacement"
NOTIFYMSG NOCOMM    "UPS %s: cannot contact UPS"

NOTIFYFLAG ONLINE   SYSLOG+WALL
NOTIFYFLAG ONBATT   SYSLOG+WALL
NOTIFYFLAG LOWBATT  SYSLOG+WALL
NOTIFYFLAG FSD      SYSLOG+WALL
NOTIFYFLAG COMMOK   SYSLOG+WALL
NOTIFYFLAG COMMBAD  SYSLOG+WALL
NOTIFYFLAG SHUTDOWN SYSLOG+WALL
NOTIFYFLAG REPLBATT SYSLOG+WALL
NOTIFYFLAG NOCOMM   SYSLOG+WALL

# Power-down flag — upsd driver reads this on restart to know whether to turn off UPS
POWERDOWNFLAG /etc/killpower

# Tuning
RBWARNTIME 43200     # Warn about battery replacement every 12 hours
NOCOMMWARNTIME 300   # Warn about lost comms after 5 minutes
FINALDELAY 5         # Wait 5 seconds before final shutdown (lets syslog flush)
