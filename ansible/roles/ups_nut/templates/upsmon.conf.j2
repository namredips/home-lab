# /etc/nut/upsmon.conf — UPS monitor config
# Managed by Ansible — do not edit manually
#
# Only UPS devices that physically power this host appear here.
# Networking-only UPS units are served by upsd but excluded from upsmon
# so they cannot trigger a server shutdown.

{% for ups in nut_monitor %}
{% set role = 'master' if ups.host == 'localhost' else 'slave' %}
MONITOR {{ ups.name }}@{{ ups.host }}:{{ ups.port | default(nut_port) }} 1 {{ nut_monitor_user }} {{ nut_monitor_password }} {{ role }}
{% endfor %}

# Shut down when all monitored supplies are lost
MINSUPPLIES {{ nut_monitor | length }}

{% set is_master = nut_monitor | selectattr('host', 'equalto', 'localhost') | list | length > 0 %}
{% if is_master %}
# This host owns the USB connection — run the full VM shutdown script before halting
SHUTDOWNCMD "/usr/local/bin/ups-shutdown.sh"
{% else %}
# Client host — pve-guests.service stops local VMs as part of normal shutdown
SHUTDOWNCMD "/sbin/shutdown -h now"
{% endif %}

POWERDOWNFLAG /etc/killpower

# Polling
POLLFREQ 5
POLLFREQALERT 5
HOSTSYNC 15
DEADTIME 15

# Notifications
NOTIFYMSG ONLINE    "UPS %s: on line power"
NOTIFYMSG ONBATT    "UPS %s: on battery"
NOTIFYMSG LOWBATT   "UPS %s: battery is low"
NOTIFYMSG FSD       "UPS %s: forced shutdown in progress"
NOTIFYMSG COMMOK    "UPS %s: communications restored"
NOTIFYMSG COMMBAD   "UPS %s: communications lost"
NOTIFYMSG SHUTDOWN  "UPS %s: shutting down"
NOTIFYMSG REPLBATT  "UPS %s: battery needs replacement"
NOTIFYMSG NOCOMM    "UPS %s: cannot contact UPS"

NOTIFYFLAG ONLINE   SYSLOG+WALL
NOTIFYFLAG ONBATT   SYSLOG+WALL
NOTIFYFLAG LOWBATT  SYSLOG+WALL
NOTIFYFLAG FSD      SYSLOG+WALL
NOTIFYFLAG COMMOK   SYSLOG+WALL
NOTIFYFLAG COMMBAD  SYSLOG+WALL
NOTIFYFLAG SHUTDOWN SYSLOG+WALL
NOTIFYFLAG REPLBATT SYSLOG+WALL
NOTIFYFLAG NOCOMM   SYSLOG+WALL

RBWARNTIME 43200
NOCOMMWARNTIME 300
FINALDELAY 5
