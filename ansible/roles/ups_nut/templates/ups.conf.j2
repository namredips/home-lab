# /etc/nut/ups.conf — UPS driver definitions (NUT server only)
# Managed by Ansible — do not edit manually

{% for device in nut_devices %}
[{{ device.name }}]
    driver = {{ device.driver | default('usbhid-ups') }}
    port   = {{ device.port | default('auto') }}
    desc   = "{{ device.desc | default(device.name) }}"
    override.battery.charge.low  = {{ device.battery_min_percent | default(20) }}
    override.battery.runtime.low = {{ device.battery_min_runtime | default(300) }}

{% endfor %}
