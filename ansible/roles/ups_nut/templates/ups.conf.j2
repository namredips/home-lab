# /etc/nut/ups.conf — UPS driver definitions (NUT server only)
# Managed by Ansible — do not edit manually

[{{ nut_ups_name }}]
    driver = {{ nut_driver }}
    port   = {{ nut_device_port }}
    desc   = "UPS ({{ nut_ups_name }})"
    # Force low-battery thresholds — upsmon triggers SHUTDOWNCMD when either is met
    override.battery.charge.low   = {{ nut_battery_min_percent }}
    override.battery.runtime.low  = {{ nut_battery_min_runtime }}
