{
  "agents": {
    "defaults": {
      "workspace": "{{ openclaw_install_dir }}/workspace",
      "model": {
        "primary": "ollama/{{ ollama_primary_model }}",
        "fallbacks": [
          "ollama/kimi-k2.5:cloud",
          "ollama/deepseek-v3.2:cloud",
          "ollama/gemini-3-flash-preview:cloud"
        ]
      },
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "every": "{{ openclaw_heartbeat_interval }}",
        "activeHours": {
          "start": "{{ openclaw_active_hours_start }}",
          "end": "{{ openclaw_active_hours_end }}",
          "timezone": "{{ openclaw_timezone }}"
        },
        "model": "ollama/gemini-3-flash-preview:cloud",
        "target": "discord",
        "ackMaxChars": 500
      },
      "maxConcurrent": {{ openclaw_max_concurrent }},
      "subagents": {
        "maxConcurrent": {{ openclaw_subagent_max_concurrent }},
        "model": "ollama/gemini-3-flash-preview:cloud"
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "identity": {
          "name": "{{ agent_name }}"
        }
      }
    ]
  },
  "models": {
    "providers": {
      "ollama": {
        "api": "openai-completions",
        "apiKey": "ollama-local",
        "baseUrl": "http://127.0.0.1:11434/v1",
        "models": [
{% for model in ollama_cloud_models %}
          {
            "contextWindow": 131072,
            "cost": {
              "cacheRead": 0,
              "cacheWrite": 0,
              "input": 0,
              "output": 0
            },
            "id": "{{ model }}",
            "input": [
              "text"
            ],
            "maxTokens": 16384,
            "name": "{{ model }}",
            "reasoning": false
          }{{ "," if not loop.last else "" }}
{% endfor %}
        ]
      }
    }
  },
  "channels": {
    "discord": {
      "enabled": true
    }
  },
  "gateway": {
    "mode": "local",
    "port": {{ openclaw_dashboard_port }}
  },
  "tools": {
    "profile": "full",
    "exec": {
      "safeBins": {{ openclaw_safe_bins | to_json }}
    }
  },
  "browser": {
    "headless": true
  },
  "logging": {
    "level": "{{ openclaw_log_level }}"
  },
  "cron": {
    "enabled": true
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "self-improvement": {
          "enabled": true,
          "path": "{{ openclaw_install_dir }}/hooks/self-improvement/handler.js"
        }
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true
  },
  "plugins": {
    "entries": {
      "discord": {
        "enabled": true
      }
    }
  }
}
