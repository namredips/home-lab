#cloud-config
# Per-agent cloud-init user-data.  Generated by Ansible; deployed as a
# Proxmox snippet so that --cicustom user= overrides the auto-generated
# user-data (which hardcodes package_upgrade: true in Proxmox 8+).
hostname: {{ agent_name }}
manage_etc_hosts: true
fqdn: {{ agent_name }}.infiquetra.com

users:
  - default

user: {{ vm_ssh_user }}
password: {{ vm_user_password_hash }}
chpasswd:
  expire: false

ssh_authorized_keys:
{% for key in vm_ssh_keys %}
  - {{ key }}
{% endfor %}

package_update: false
package_upgrade: false
